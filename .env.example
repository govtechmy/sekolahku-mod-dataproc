# MongoDB connection
MONGO_URI=mongodb://username:password@localhost:27017/
DB_NAME=sekolahku

# Source selector: csv | gsheet (can be overridden by --source CLI arg)
SOURCE=csv

# CSV fallback path (relative to project root)
CSV_PATH=data/sekolah.csv

# Google Sheets (only required if SOURCE=gsheet)
# Obtain the Sheet ID from the URL: https://docs.google.com/spreadsheets/d/<GSHEET_ID>/edit
GSHEET_ID=
# Worksheet (tab) name inside the sheet
GSHEET_WORKSHEET_NAME=Sheet1

# Service account credentials JSON for Google APIs
# If left blank, code looks for service_account.json in project root
GOOGLE_APPLICATION_CREDENTIALS=service_account.json

# Max docs per bulk_write batch
BATCH_SIZE=500
# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Set to 1 for ingestion dry run from environment (overridden by CLI --dry-run)
DRY_RUN=0
