# AWS Secrets Manager
AWS_SECRETS_NAME=sekolahku-mod-dataproc-secret-dev

# AWS S3 Configuration for Kawasanku Data
S3_BUCKET=my.gov.digital.sekolahku-app-dev-opendosm-raw
S3_REGION=ap-southeast-5
AWS_PROFILE=slz-dev

# MongoDB connection
MONGO_URI=mongodb://username:password@localhost:27017/
DB_NAME=sekolahku
SEKOLAH_COLLECTION=Sekolah 
ENTITI_SEKOLAH_COLLECTION=EntitiSekolah
ANALITIK_SEKOLAH_COLLECTION=AnalitikSekolah
NEGERI_PARLIMEN_KOD_SEKOLAH_COLLECTION=NegeriParlimenKodSekolah

# CSV ingestion path (relative to project root)
CSV_PATH=data/sekolah.csv

# Max docs per bulk_write batch
BATCH_SIZE=500
# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
