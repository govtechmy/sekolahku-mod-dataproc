FROM python:3.13.8-slim

# Python runtime settings
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    AWS_SECRETS_NAME=sekolahku-mod-dataproc-secret-dev \
    AWS_REGION=ap-southeast-1

WORKDIR /app

# System dependencies for common scientific and crypto libs
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    libpq-dev \
    libffi-dev \
    curl \
    && rm -rf /var/lib/apt/lists/* \
    && pip install --no-cache-dir --upgrade pip setuptools wheel

# Install pinned Python dependencies first for better layer caching
COPY requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r /app/requirements.txt

# Copy project source code
COPY src /app/src
COPY main.py /app/main.py

# Default command runs the main Python application
CMD ["python", "main.py"]
