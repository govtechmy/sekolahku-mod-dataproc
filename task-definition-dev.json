{
  "containerDefinitions": [
    {
      "image": "602670427499.dkr.ecr.ap-southeast-5.amazonaws.com/sekolahku-mod-dataproc-dev:latest",
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/sekolahku-mod-dataproc-dev",
          "awslogs-region": "ap-southeast-5",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "name": "sekolahku-mod-dataproc",
      "portMappings": [{ "containerPort": 8080, "hostPort": 8080, "name": "sekolahku-mod-dataproc" }],
      "stopTimeout": 2
    }
  ],
  "cpu": "512",
  "executionRoleArn": "arn:aws:iam::602670427499:role/sekolahku-ecsTaskExecutionRole-dev",
  "family": "sekolahku-mod-dataproc-dev",
  "memory": "1024",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "taskRoleArn": "arn:aws:iam::602670427499:role/sekolahku-ecs-task-role-dev"
}